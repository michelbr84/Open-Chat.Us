# Supabase Configuration
# Get these values from your Supabase project dashboard
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here
VITE_SUPABASE_URL=https://your_project_id.supabase.co

# n8n Webhook Configuration (for AI Bot integration)
# Set up your n8n workflow and add the webhook URL here
VITE_N8N_WEBHOOK_URL=your_n8n_webhook_url_here

# Optional: Analytics and Monitoring
# VITE_ANALYTICS_ENABLED=false